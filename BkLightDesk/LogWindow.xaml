<Window x:Class="BkLightDesk.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Attività" Height="400" Width="600"
        Background="#1E1E1E">
    <Grid>
        <TextBox x:Name="TxtOutput"
                 Margin="10"
                 Background="#1E1E1E"
                 Foreground="#00FF00"
                 FontFamily="Consolas"
                 FontSize="14"
                 BorderThickness="0"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"/>
    </Grid>
</Window>