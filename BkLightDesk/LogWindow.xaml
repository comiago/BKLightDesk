<Window x:Class="BkLightDesk.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Console di Sistema" Height="450" Width="650"
        Background="#09090B" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="#10B981" Margin="0,0,10,0">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="8" Color="#10B981" ShadowDepth="0" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <TextBlock Text="TERMINALE ATTIVITÀ" Foreground="#A1A1AA" FontWeight="Bold" FontSize="12" />
        </StackPanel>

        <Border Grid.Row="1" Background="#121214" CornerRadius="16" BorderBrush="#27272A" BorderThickness="1" Padding="15">
            <TextBox x:Name="TxtOutput"
                     Background="Transparent"
                     Foreground="#10B981" 
                     FontFamily="Consolas"
                     FontSize="13"
                     BorderThickness="0"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     SelectionBrush="#27272A"
                     CaretBrush="Transparent"/>
        </Border>
    </Grid>
</Window>