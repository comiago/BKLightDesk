<Window x:Class="BkLightDesk.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" 
        Width="400" 
        SizeToContent="Height" 
        Background="#09090B" 
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#121214"/>
        <SolidColorBrush x:Key="CardBorder" Color="#27272A"/>
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A1A1AA"/>

        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#09090B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" Foreground="{StaticResource TextMain}" FontWeight="Black" FontSize="24" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1">
            
            <Border Background="{StaticResource CardBg}" CornerRadius="16" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="18" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="MATRIX BRIGHTNESS" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="Heavy" Margin="0,0,0,15"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Slider x:Name="SliderBrightness" Grid.Column="0"
                                Minimum="1" Maximum="100" Value="100"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" Margin="0,0,15,0"
                                ValueChanged="SliderBrightness_ValueChanged"
                                Thumb.DragCompleted="SliderBrightness_DragCompleted"/>
                        
                        <Border Grid.Column="1" Background="#18181B" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1" Width="60" Height="34">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBox x:Name="TxtBrightnessInput"
                                         Text="100" Width="32"
                                         Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0"
                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                         MaxLength="3" FontSize="13" FontWeight="Bold"
                                         PreviewTextInput="TxtBrightnessInput_PreviewTextInput"
                                         TextChanged="TxtBrightnessInput_TextChanged"
                                         CaretBrush="White"/>
                                <TextBlock Text="%" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontSize="12" Margin="2,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBg}" CornerRadius="16" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="18">
                <StackPanel>
                    <CheckBox x:Name="ChkTurbo" Foreground="{StaticResource TextMain}" FontSize="14" FontWeight="SemiBold"
                              Checked="ChkTurbo_Checked" Unchecked="ChkTurbo_Unchecked">
                        <CheckBox.Content>
                            <TextBlock Text="Turbo Mode (Low Latency)" Margin="8,0,0,0" Padding="0,0,0,2"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <TextBlock Text="⚠️ Experimental: Optimizes frame transmission to reduce image upload lag." 
                               Foreground="#71717A" FontSize="12" Margin="32,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>

        <Button Grid.Row="2" Content="Save &amp; Close" Style="{StaticResource PrimaryBtn}" Margin="0,20,0,0" Click="BtnClose_Click"/>
    </Grid>
</Window>