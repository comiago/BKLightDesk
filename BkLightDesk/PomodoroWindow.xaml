<Window x:Class="BkLightDesk.PomodoroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Setup" Height="400" Width="350"
        Background="#09090B" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI Variable Display, Segoe UI, Arial">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBg" Color="#121214"/>
        <SolidColorBrush x:Key="CardBorder" Color="#27272A"/>
        <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextMuted" Color="#A1A1AA"/>

        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#EF4444"/> 
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="POMODORO TIMER" Foreground="#EF4444" FontWeight="Heavy" FontSize="11"/>
            <TextBlock Text="Session Setup" Foreground="{StaticResource TextMain}" FontWeight="Black" FontSize="24" Margin="0,-2,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" CornerRadius="20" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="20">
            <StackPanel VerticalAlignment="Center">
                
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="⏱️ Work (minutes)" Foreground="{StaticResource TextMuted}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#18181B" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1" Width="60" Height="34">
                        <TextBox x:Name="TxtWork" Text="25" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" 
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MaxLength="2" FontSize="14" FontWeight="Bold" CaretBrush="White"/>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="☕ Break (minutes)" Foreground="{StaticResource TextMuted}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#18181B" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1" Width="60" Height="34">
                        <TextBox x:Name="TxtBreak" Text="5" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" 
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MaxLength="2" FontSize="14" FontWeight="Bold" CaretBrush="White"/>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔄 Total Cycles" Foreground="{StaticResource TextMuted}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Background="#18181B" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1" Width="60" Height="34">
                        <TextBox x:Name="TxtCycles" Text="4" Background="Transparent" Foreground="{StaticResource TextMain}" BorderThickness="0" 
                                 VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MaxLength="2" FontSize="14" FontWeight="Bold" CaretBrush="White"/>
                    </Border>
                </Grid>

            </StackPanel>
        </Border>

        <Button Grid.Row="2" Content="🚀 Start Focus Session" Style="{StaticResource PrimaryBtn}" Margin="0,20,0,0" Click="BtnStart_Click"/>
    </Grid>
</Window>